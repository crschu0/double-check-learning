rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email == "cschuchard@maldenschool.org";
    }

    function hasApprovedEmail() {
      return signedIn()
        && request.auth.token.email in [
          "cschuchard@maldenschool.org",
          "lcunniff@maldenschool.org",
          "anichols@maldenschool.org",
          "slennon@maldenschool.org",
          "mpatterson@maldenschool.org",
          "jribas@maldenschool.org"
        ];
    }

    function hasApprovedUserDoc(uid) {
      return signedIn()
        && exists(/databases/$(database)/documents/approvedUsers/$(uid))
        && get(/databases/$(database)/documents/approvedUsers/$(uid)).data.status == "approved";
    }

    function isApprovedTeacher() {
      return hasApprovedEmail() || hasApprovedUserDoc(request.auth.uid);
    }

    match /accessRequests/{uid} {
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.status == "pending";
      allow read, update, delete: if isAdmin();
    }

    match /approvedUsers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /trackerData/incentives {
      allow read: if isApprovedTeacher();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (isApprovedTeacher()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["points", "updatedAt"]));
    }

    match /privateProgress/progress {
      allow read, write: if isAdmin();
    }

    match /publicProgress/studentProgress {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
