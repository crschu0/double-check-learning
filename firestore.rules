rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      return signedIn()
        && request.auth.token.email in [
          "doublechecklearning@gmail.com",
          "cschuchard@maldenschool.org"
        ];
    }

    function isApprovedUser(uid) {
      return signedIn()
        && exists(/databases/$(database)/documents/approvedUsers/$(uid))
        && get(/databases/$(database)/documents/approvedUsers/$(uid)).data.status == "approved";
    }

    match /accessRequests/{uid} {
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow read, update, delete: if isTeacher();
    }

    match /approvedUsers/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isTeacher());
      allow create, update, delete: if isTeacher();
    }

    match /trackerData/{document=**} {
      allow read, write: if isTeacher() || isApprovedUser(request.auth.uid);
    }
  }
}
